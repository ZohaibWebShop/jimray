    "custom_liquid_qeTkWW": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<div style=\"font-family: Arial, sans-serif; margin: 20px 0;\">\n  <div style=\"display: inline-block; padding: 12px 24px; background-color: #ececec; border: 2px solid #333; border-bottom: none; border-radius: 10px 10px 0 0; font-weight: bold; font-size: 16px; position: relative; top: 2px; z-index: 2;\">\n    Specifications\n  </div>\n  \n  <table style=\"width: 100%; border: 2px solid #333; border-collapse: collapse; position: relative; z-index: 1;\" cellspacing=\"0\" cellpadding=\"0\">\n    <tbody>\n      <tr style=\"background-color: #ececec;\">\n        <td style=\"padding: 16px; width: 35%; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">General Capabilities</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Die Forming<br>Die Cutting</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">Extruded</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ffffff;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Gasket Types</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Lockscrew Packing<br>Stem Packing</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">LCP Packing</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ececec;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Gasket Shape</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <span style=\"line-height: 1.6;\">Round</span>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ffffff;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Materials</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Graphite<br>Stainless Steel Wire Mesh</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">Inconel® Caps</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ececec;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Resistances</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Corrosion<br>Detergents<br>Grease<br>Oil</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">Rust<br>Salts<br>Steam<br>Water</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ffffff;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Temperature Range</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Min<br>-100 °F</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">Max<br>800 °F (air)<br>1200 °F (steam)</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ececec;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Pressure Range<br>with proper design</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <span style=\"line-height: 1.6;\">Max<br>20,000 psi</span>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ffffff;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Inner/Outer Diameter</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Min<br>.3 in</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">Max<br>24 in</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ececec;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Thickness</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <table border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"width: 100%;\">\n            <tbody>\n              <tr>\n                <td style=\"width: 50%; vertical-align: top; padding-right: 10px;\">\n                  <span style=\"line-height: 1.6;\">Min<br>.010 in</span>\n                </td>\n                <td style=\"width: 50%; vertical-align: top;\">\n                  <span style=\"line-height: 1.6;\">Max<br>2 in</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ffffff;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Tolerance (+/-)</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <span style=\"line-height: 1.6;\">.010 in</span>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ececec;\">\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <h6 style=\"margin: 0; font-size: 15px;\">Density Tolerance (+/-)</h6>\n        </td>\n        <td style=\"padding: 16px; vertical-align: top;\">\n          <span style=\"line-height: 1.6;\">5 lb/ft<sup>3</sup></span>\n        </td>\n      </tr>\n      \n      <tr style=\"background-color: #ffffff;