<script src="{{ 'quote-request.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="page-width section-{{ section.id }}-padding"
  data-quote-page
  data-quote-request-config
  data-api-base-url="{{ settings.quote_api_base_url }}"
  data-secret="{{ settings.quote_api_secret }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
  data-customer-name="{% if customer %}{{ customer.name }}{% endif %}"
>
  <div style="width: 100%; max-width: 920px; margin: 0 auto;">
    <h1 class="main-page-title page-title h0">{{ page.title | escape }}</h1>

    {% if customer == null %}
      <div class="rte">
        <p>Login to your account to view and submit quote requests.</p>
        <a class="button" href="{{ routes.account_login_url }}">Login</a>
      </div>
    {% else %}
      {% if request.params.submitted == '1' %}
        <div class="cart__warnings">
          <h2 class="cart__login-title">Quote request submitted.</h2>
          <p>We have received your quote request. A confirmation email has been sent.</p>
        </div>
      {% endif %}

      <div class="rte">
        {{ page.content }}
      </div>

      <div style="margin-top: 2rem;">
        <h2 class="h2">Submit current quote list</h2>
        <p>Your current quote list is based on the items currently in <b>your cart</b>.</p>

        <div class="field" style="margin-bottom: 1rem; max-width: 700px;">
          <textarea
            class="text-area field__input"
            rows="4"
            data-quote-note
            placeholder="Enter any specific instructions or requirements"
          ></textarea>
          <label class="form__label field__label">Special instructions / notes</label>
        </div>

        <div style="display:flex; gap: 1rem; align-items:center;">
          <button class="button" data-quote-submit type="button">Submit quote request</button>
          <span data-quote-submit-spinner hidden>Submitting...</span>
          <a href="{{ routes.cart_url }}" class="button button--secondary center">View / edit quote list</a>
        </div>

        <p data-quote-message-ok hidden style="color: green; margin-top: 0.75rem;"></p>
        <p data-quote-message-error hidden style="color: #cc0000; margin-top: 0.75rem;"></p>
      </div>
      
      <hr>

      <div style="margin-top: 3rem; max-width: 920px; margin-left: auto; margin-right: auto;">
        <h2 class="h2">Your previous quote requests</h2>
        <div data-quote-history>
          <p>Loading...</p>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main quote",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
