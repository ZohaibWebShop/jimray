{% doc %}
  Free quote submission form - allows both logged-in and guest users to submit quote requests.
  If user is logged in, pre-fills customer details. Otherwise, allows custom details.
  Integrates with cart items and submits to quote API.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-contact-form__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    font-weight: 600;
  }

  .ai-contact-form__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-contact-form__field-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-contact-form__field-group-{{ ai_gen_id }}.animate-in {
    animation: ai-contact-form-slide-in-{{ ai_gen_id }} 0.5s ease forwards;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-contact-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background }};
    transition: all 0.3s ease;
    width: 100%;
    box-sizing: border-box;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.primary_color }};
    box-shadow: 0 0 0 3px {{ block.settings.primary_color }}33;
    transform: translateY(-2px);
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
    font-family: inherit;
  }

  .ai-contact-form__collections-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }

  .ai-contact-form__checkbox-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    border: 2px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-contact-form__checkbox-wrapper-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.primary_color }};
    transform: translateY(-2px);
    box-shadow: 0 4px 12px {{ block.settings.primary_color }}1a;
  }

  .ai-contact-form__checkbox-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    cursor: pointer;
    accent-color: {{ block.settings.primary_color }};
  }

  .ai-contact-form__checkbox-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    flex: 1;
  }

  .ai-contact-form__other-input-{{ ai_gen_id }} {
    margin-top: 12px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.3s ease;
  }

  .ai-contact-form__other-input-{{ ai_gen_id }}.show {
    max-height: 100px;
    opacity: 1;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: 16px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .ai-contact-form__button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background-color: {{ block.settings.button_hover_color }};
    transform: translate(-50%, -50%);
    transition: width 0.5s ease, height 0.5s ease;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover::before {
    width: 300%;
    height: 300%;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px {{ block.settings.button_color }}4d;
  }

  .ai-contact-form__button-text-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_color }}1a;
    border: 2px solid {{ block.settings.success_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    color: {{ block.settings.success_color }};
    font-size: 14px;
    text-align: center;
    margin-top: 16px;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_color }}1a;
    border: 2px solid {{ block.settings.error_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    color: {{ block.settings.error_color }};
    font-size: 14px;
    margin-top: 16px;
  }

  .ai-contact-form__cart-items-{{ ai_gen_id }} {
    margin-bottom: 30px;
    padding: 20px;
    background-color: #f9f9f9;
    border-radius: {{ block.settings.input_border_radius }}px;
    border: 1px solid #e0e0e0;
  }

  .ai-contact-form__cart-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e0e0e0;
  }

  .ai-contact-form__cart-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-contact-form__cart-count-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_color }};
    color: white;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
  }

  .ai-contact-form__cart-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-contact-form__cart-empty-{{ ai_gen_id }} {
    text-align: center;
    color: #666;
    font-size: 14px;
    padding: 20px;
    margin: 0;
  }

  .ai-contact-form__cart-item-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    padding: 10px;
    background-color: white;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
    align-items: center;
  }

  .ai-contact-form__cart-item-image-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .ai-contact-form__cart-item-details-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-contact-form__cart-item-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ai-contact-form__cart-item-variant-{{ ai_gen_id }} {
    font-size: 12px;
    color: #666;
    margin: 0;
  }

  .ai-contact-form__cart-item-qty-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
    font-weight: 500;
    flex-shrink: 0;
  }

  @keyframes ai-contact-form-slide-in-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding | times: 0.6 }}px;
    }

    .ai-contact-form__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-contact-form__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-contact-form__collections-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }}
  class="ai-contact-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-quote-request-config
  data-api-base-url="{{ settings.quote_api_base_url }}"
  data-secret="{{ settings.quote_api_secret }}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  data-customer-email="{% if customer %}{{ customer.email }}{% endif %}"
  data-customer-name="{% if customer %}{{ customer.name }}{% endif %}"
>
  <div class="ai-contact-form__header-{{ ai_gen_id }}">
    <h2 class="ai-contact-form__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    <div class="ai-contact-form__description-{{ ai_gen_id }}">
      {{ block.settings.description }}
    </div>
  </div>

  <div class="ai-contact-form__cart-items-{{ ai_gen_id }}" data-quote-cart-items>
    <div class="ai-contact-form__cart-header-{{ ai_gen_id }}">
      <h3 class="ai-contact-form__cart-title-{{ ai_gen_id }}">Items in Your Quote</h3>
      <span class="ai-contact-form__cart-count-{{ ai_gen_id }}" data-cart-count>0</span>
    </div>
    <div class="ai-contact-form__cart-list-{{ ai_gen_id }}" data-cart-list>
      <p class="ai-contact-form__cart-empty-{{ ai_gen_id }}">
        Your quote list is empty. Please add items to your quote.
      </p>
    </div>
  </div>

  <div class="ai-contact-form__form-{{ ai_gen_id }}" data-quote-free-form>
    <div class="ai-contact-form__field-group-{{ ai_gen_id }}" data-delay="0">
      <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.name_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="text"
        id="contact-name-{{ ai_gen_id }}"
        name="name"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{% if customer %}{{ customer.name }}{% endif %}"
        required
        aria-required="true"
        placeholder="{{ block.settings.name_placeholder }}"
        data-quote-customer-name
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}" data-delay="100">
      <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.email_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <input
        type="email"
        id="contact-email-{{ ai_gen_id }}"
        name="email"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{% if customer %}{{ customer.email }}{% endif %}"
        required
        aria-required="true"
        autocomplete="email"
        placeholder="{{ block.settings.email_placeholder }}"
        data-quote-customer-email
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}" data-delay="200">
      <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.phone_label }}
      </label>
      <input
        type="tel"
        id="contact-phone-{{ ai_gen_id }}"
        name="phone"
        class="ai-contact-form__input-{{ ai_gen_id }}"
        value="{% if customer %}{{ customer.phone }}{% endif %}"
        autocomplete="tel"
        placeholder="{{ block.settings.phone_placeholder }}"
        data-quote-customer-phone
      >
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}" data-delay="300">
      <label class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.collections_label }}
        <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
      </label>
      <div class="ai-contact-form__collections-{{ ai_gen_id }}">
        {% if block.settings.collections != blank %}
          {% for collection in block.settings.collections %}
            <div class="ai-contact-form__checkbox-wrapper-{{ ai_gen_id }}">
              <input
                type="checkbox"
                id="collection-{{ collection.id }}-{{ ai_gen_id }}"
                name="interested_in"
                value="{{ collection.title }}"
                class="ai-contact-form__checkbox-{{ ai_gen_id }}"
                data-quote-interest
              >
              <label
                for="collection-{{ collection.id }}-{{ ai_gen_id }}"
                class="ai-contact-form__checkbox-label-{{ ai_gen_id }}"
              >
                {{ collection.title }}
              </label>
            </div>
          {% endfor %}
        {% endif %}

        <div class="ai-contact-form__checkbox-wrapper-{{ ai_gen_id }}">
          <input
            type="checkbox"
            id="other-checkbox-{{ ai_gen_id }}"
            name="interested_in"
            value="Other"
            class="ai-contact-form__checkbox-{{ ai_gen_id }} ai-contact-form__other-checkbox-{{ ai_gen_id }}"
            data-quote-interest
          >
          <label for="other-checkbox-{{ ai_gen_id }}" class="ai-contact-form__checkbox-label-{{ ai_gen_id }}">
            {{ block.settings.other_label }}
          </label>
        </div>
      </div>

      <div class="ai-contact-form__other-input-{{ ai_gen_id }}" id="other-input-wrapper-{{ ai_gen_id }}">
        <input
          type="text"
          id="other-input-{{ ai_gen_id }}"
          name="other_interest"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.other_placeholder }}"
          data-quote-other-interest
        >
      </div>
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}" data-delay="400">
      <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
        {{ block.settings.message_label }}
      </label>
      <textarea
        id="contact-message-{{ ai_gen_id }}"
        name="message"
        class="ai-contact-form__textarea-{{ ai_gen_id }}"
        placeholder="{{ block.settings.message_placeholder }}"
        data-quote-note
      ></textarea>
    </div>

    <div class="ai-contact-form__field-group-{{ ai_gen_id }}" data-delay="500">
      <button type="button" class="ai-contact-form__button-{{ ai_gen_id }}" data-quote-free-submit>
        <span class="ai-contact-form__button-text-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
      </button>
    </div>

    <div class="ai-contact-form__message-{{ ai_gen_id }}" data-quote-message style="display:none;"></div>
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.animateFields();
        this.setupOtherOption();
        this.setupQuoteSubmission();
        this.loadCartItems();
      }

      animateFields() {
        const fields = this.querySelectorAll('.ai-contact-form__field-group-{{ ai_gen_id }}');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const delay = entry.target.dataset.delay || 0;
              setTimeout(() => {
                entry.target.classList.add('animate-in');
              }, delay);
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1
        });

        fields.forEach((field) => {
          observer.observe(field);
        });
      }

      setupQuoteSubmission() {
        const submitBtn = this.querySelector('[data-quote-free-submit]');
        if (!submitBtn) return;

        submitBtn.addEventListener('click', async (e) => {
          e.preventDefault();
          await this.handleQuoteSubmit();
        });
      }

      async handleQuoteSubmit() {
        const submitButton = this.querySelector('[data-quote-free-submit]');
        const buttonText = submitButton.querySelector('.ai-contact-form__button-text-{{ ai_gen_id }}');
        const originalText = buttonText.textContent;

        // Validate form
        const nameInput = this.querySelector('[data-quote-customer-name]');
        const emailInput = this.querySelector('[data-quote-customer-email]');
        const checkboxes = this.querySelectorAll('[data-quote-interest]');

        if (!nameInput.value.trim()) {
          this.showErrorMessage('Please enter your name');
          return;
        }

        if (!emailInput.value.trim()) {
          this.showErrorMessage('Please enter your email');
          return;
        }

        const isChecked = Array.from(checkboxes).some(cb => cb.checked);
        if (!isChecked) {
          this.showErrorMessage('Please select at least one option from "Interested in"');
          return;
        }

        try {
          buttonText.textContent = 'Submitting...';
          submitButton.disabled = true;
          this.clearMessages();

          // Get cart items
          const cartResponse = await fetch('/cart.js');
          const cart = await cartResponse.json();

          if (!cart.items || cart.items.length === 0) {
            this.showErrorMessage('Your quote list is empty. Please add items to your quote before submitting.');
            return;
          }

          // Get config
          const config = this.getConfig();
          if (!config.apiBaseUrl || !config.secret) {
            this.showErrorMessage('Quote system is not configured. Please contact support.');
            return;
          }

          // Build customer data
          const customerName = nameInput.value.trim();
          const customerEmail = emailInput.value.trim();
          const customerPhone = this.querySelector('[data-quote-customer-phone]')?.value.trim() || '';

          // Build note with interests and message
          const interests = Array.from(checkboxes)
            .filter(cb => cb.checked)
            .map(cb => cb.value);
          const otherInterest = this.querySelector('[data-quote-other-interest]')?.value.trim() || '';
          const message = this.querySelector('[data-quote-note]')?.value.trim() || '';

          let noteText = '';
          if (interests.length > 0) {
            noteText += 'Interested in: ' + interests.join(', ');
            if (otherInterest && interests.includes('Other')) {
              noteText += ' (' + otherInterest + ')';
            }
            noteText += '\n\n';
          }
          if (message) {
            noteText += message;
          }

          // Map cart items to quote format
          const items = cart.items.map(item => ({
            productId: String(item.product_id || ''),
            variantId: String(item.variant_id || item.id || ''),
            title: item.product_title || item.title || '',
            variantTitle: item.variant_title || '',
            sku: item.sku || '',
            quantity: item.quantity,
            price: item.price / 100,
            imageUrl: item.image || item.featured_image?.url || '',
            productUrl: item.url || ''
          }));

          // Submit quote
          const response = await fetch(`${config.apiBaseUrl}/api/quotes`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-QUOTE-SECRET': config.secret
            },
            body: JSON.stringify({
              customer: {
                shopifyCustomerId: config.customerId || null,
                email: customerEmail,
                name: customerName,
                phone: customerPhone || null
              },
              note: noteText,
              items
            })
          });

          if (!response.ok) {
            const errorData = await response.json().catch(() => ({}));
            throw new Error(errorData.error || 'Failed to submit quote');
          }

          const result = await response.json();

          // Clear cart
          await fetch('/cart/clear.js', { method: 'POST' });

          // Show success and redirect
          this.showSuccessMessage();
          
          setTimeout(() => {
            if (result.quoteId && config.customerId) {
              window.location.href = `/pages/quote-details?quoteId=${encodeURIComponent(result.quoteId)}`;
            } else {
              window.location.href = '/pages/free-quote?submitted=1';
            }
          }, 1500);

        } catch (error) {
          console.error('Quote submission error:', error);
          this.showErrorMessage(error.message || 'Failed to submit quote. Please try again.');
        } finally {
          buttonText.textContent = originalText;
          submitButton.disabled = false;
        }
      }

      getConfig() {
        return {
          apiBaseUrl: this.dataset.apiBaseUrl || '',
          secret: this.dataset.secret || '',
          customerId: this.dataset.customerId || '',
          customerEmail: this.dataset.customerEmail || '',
          customerName: this.dataset.customerName || ''
        };
      }

      async loadCartItems() {
        try {
          const response = await fetch('/cart.js');
          const cart = await response.json();
          
          const cartList = this.querySelector('[data-cart-list]');
          const cartCount = this.querySelector('[data-cart-count]');
          
          if (!cartList || !cartCount) return;
          
          cartCount.textContent = cart.item_count || 0;
          
          if (!cart.items || cart.items.length === 0) {
            cartList.innerHTML = '<p class="ai-contact-form__cart-empty-{{ ai_gen_id }}">Your quote list is empty. Please add items to your quote.</p>';
            return;
          }
          
          const itemsHTML = cart.items.map(item => {
            const image = item.image || item.featured_image?.url || '';
            const title = item.product_title || item.title || '';
            const variant = item.variant_title || '';
            const quantity = item.quantity || 1;
            
            return `
              <div class="ai-contact-form__cart-item-{{ ai_gen_id }}">
                ${image ? `<img src="${image}" alt="${title}" class="ai-contact-form__cart-item-image-{{ ai_gen_id }}">` : ''}
                <div class="ai-contact-form__cart-item-details-{{ ai_gen_id }}">
                  <p class="ai-contact-form__cart-item-title-{{ ai_gen_id }}">${title}</p>
                  ${variant ? `<p class="ai-contact-form__cart-item-variant-{{ ai_gen_id }}">${variant}</p>` : ''}
                </div>
                <span class="ai-contact-form__cart-item-qty-{{ ai_gen_id }}">Qty: ${quantity}</span>
              </div>
            `;
          }).join('');
          
          cartList.innerHTML = itemsHTML;
        } catch (error) {
          console.error('Error loading cart items:', error);
        }
      }

      setupOtherOption() {
        const otherCheckbox = this.querySelector('.ai-contact-form__other-checkbox-{{ ai_gen_id }}');
        const otherInputWrapper = this.querySelector('#other-input-wrapper-{{ ai_gen_id }}');
        const otherInput = this.querySelector('#other-input-{{ ai_gen_id }}');

        if (otherCheckbox && otherInputWrapper && otherInput) {
          otherCheckbox.addEventListener('change', function() {
            if (this.checked) {
              otherInputWrapper.classList.add('show');
              otherInput.focus();
            } else {
              otherInputWrapper.classList.remove('show');
              otherInput.value = '';
            }
          });
        }
      }


      clearMessages() {
        const messageDiv = this.querySelector('[data-quote-message]');
        if (messageDiv) {
          messageDiv.style.display = 'none';
          messageDiv.textContent = '';
          messageDiv.className = 'ai-contact-form__message-{{ ai_gen_id }}';
        }
      }

      showSuccessMessage() {
        const messageDiv = this.querySelector('[data-quote-message]');
        if (messageDiv) {
          messageDiv.className = 'ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__success-{{ ai_gen_id }}';
          messageDiv.textContent = {{ block.settings.success_message | json }};
          messageDiv.style.display = 'block';
          messageDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      showErrorMessage(message) {
        const messageDiv = this.querySelector('[data-quote-message]');
        if (messageDiv) {
          messageDiv.className = 'ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__error-{{ ai_gen_id }}';
          messageDiv.textContent = message;
          messageDiv.style.display = 'block';
          messageDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

