<style>
  #shopify-block-{{ block.id }}{
    padding: 0;

    @media screen and (max-width: 749px) {
      width: 100%;
      padding-top: 30px;
    }
  }

  .experience-counter-block {
    position: relative;
    display: flex;
    justify-content: center;
    padding: 30px 40px;
    max-width:100%;
    overflow: visible;
    transition: transform 0.3s ease;

    @media screen and (max-width: 749px) {
      padding: 20px;
    }
  }
  .experience-counter-block:before{
    content:"";
    position:absolute;
    width: 100%;
    height:100%;
    top:0px;
    background-color: RGBA(192,183,183,1);
    clip-path: polygon(5% 0, 100% 0, 100% 75%, 95% 100%, 0 100%, 0 25%);
  }

  /* .experience-counter-block:hover {
    transform: translate({{ block.settings.counter_x_position }}px, {{ block.settings.counter_y_position }}px) scale(1.05);
  } */

  .experience-counter-number {
    position:absolute;
    left:50%;
    top: 0;
    transform: translate(-50%, -50%);
    font-family:'Plus Jakarta Sans','sans-serif';
    font-size: {{ block.settings.counter_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.counter_text_color }};
    line-height: 1;
    margin: 0;
    transition: transform 0.3s ease;

    @media screen and (max-width: 749px) {
      font-size: 50px;
    }
  }

  .experience-counter-text {
    font-family:'Plus Jakarta Sans','sans-serif';
    font-size: 32px;
    color: #333333;
    font-weight: 700;
    line-height:1;
    z-index:1;

    margin: 0;
    margin-top:20px;
    opacity: 1;

    @media screen and (max-width: 749px) {
      margin-top: 10px;
    }
  }
</style>

<div class="experience-counter-block pulse" data-counter-target="{{ block.settings.counter_target }}">
  <div class="experience-counter-number">{{ block.settings.counter_target }}+</div>
  <div class="experience-counter-text">{{ block.settings.counter_text }}</div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const counters = document.querySelectorAll('.experience-counter-block');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );

    counters.forEach((counter) => {
      observer.observe(counter);
    });

    function animateCounter(counter) {
      const target = +counter.dataset.counterTarget;
      const numberEl = counter.querySelector('.experience-counter-number');
      const duration = 2000;
      const startTime = performance.now();

      function update(timestamp) {
        const progress = timestamp - startTime;
        const percentage = Math.min(progress / duration, 1);
        const value = Math.floor(percentage * target);
        numberEl.textContent = value + '+';

        if (percentage < 1) {
          requestAnimationFrame(update);
        }
      }

      requestAnimationFrame(update);
    }
  });
</script>

{% schema %}
{
  "name": "Experience Counter",
  "settings": [
    {
      "type": "number",
      "id": "counter_target",
      "label": "Counter Target",
      "default": 40
    },
    {
      "type": "text",
      "id": "counter_text",
      "label": "Counter Text",
      "default": "Years of experience"
    },
    {
      "type": "number",
      "id": "counter_font_size",
      "label": "Counter Font Size",
      "default": 40
    },
    {
      "type": "color",
      "id": "counter_text_color",
      "label": "Counter Text Color",
      "default": "#333333"
    },
    {
      "type": "number",
      "id": "counter_x_position",
      "label": "Counter X Position",
      "default": 0
    },
    {
      "type": "number",
      "id": "counter_y_position",
      "label": "Counter Y Position",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Experience Counter"
    }
  ]
}
{% endschema %}
